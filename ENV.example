# clawfeedradar ENV.example
# Copy this file to `.env` and replace placeholder values (EMBEDDING_*, SMALL_LLM_*, paths) as needed.

# --- Embedding service (shared with clawsqlite) ---
# Used both by clawsqlite and clawfeedradar for all embedding calls.
EMBEDDING_BASE_URL=https://embed.example.com/v1
EMBEDDING_MODEL=your-embedding-model
EMBEDDING_API_KEY=sk-your-embedding-key

# Vector dimension for the embedding model (must match clawsqlite side)
CLAWSQLITE_VEC_DIM=1024

# Optional embedding client tuning
# Number of times to retry on timeouts / transient errors (default: 3).
CLAWFEEDRADAR_EMBED_RETRIES=3
# Backoff between retries in seconds (default: 1.0).
CLAWFEEDRADAR_EMBED_RETRY_BACKOFF_SEC=1.0
# Extra sleep between *successful* embedding calls (milliseconds).
# Useful when going through Cloudflare or rate-limited proxies.
CLAWFEEDRADAR_EMBED_SLEEP_BETWEEN_MS=0

# --- Knowledge base location (clawsqlite) ---
# Root directory that contains clawsqlite data (knowledge DB, etc.).
CLAWSQLITE_ROOT=/home/node/.openclaw/workspace/knowledge_data
# Optional explicit DB path override
# If omitted, clawfeedradar derives it from CLAWSQLITE_ROOT.
# CLAWSQLITE_DB=/home/node/.openclaw/workspace/knowledge_data/knowledge.sqlite3

# --- Source list for clawfeedradar schedule ---
# Path to sources.json used by `clawfeedradar schedule`.
CLAWFEEDRADAR_SOURCES_JSON=/home/node/.openclaw/workspace/clawfeedradar/clawfeedradar/sources.json

# --- Output directory for feeds ---
# Per-source XML/JSON files (and single-run outputs) will be written here.
CLAWFEEDRADAR_OUTPUT_DIR=/home/node/.openclaw/workspace/clawfeedradar/feeds

# --- Scraping ---
# External command used to fetch fulltext for a given URL.
# It should accept the URL as its last argument and emit markdown/text to stdout.
# Recommended: a thin wrapper around `clawfetch`.
CLAWFEEDRADAR_SCRAPE_CMD="/home/node/.openclaw/workspace/clawfetch_wrapper.sh"

# Cross-host concurrency for fulltext fetching (per-host still serialized).
CLAWFEEDRADAR_SCRAPE_WORKERS=4

# Optional custom User-Agent for HTTP requests (embedding/LLM/scrape).
# If unset, a default clawfeedradar UA is used.
# CLAWFEEDRADAR_HTTP_USER_AGENT=Mozilla/5.0 (X11; Linux x86_64) Clawfeedradar/0.1

# --- Logging ---
# Global log level for clawfeedradar + httpx loggers.
CLAWFEEDRADAR_LOG_LEVEL=INFO

# --- Interest mixing weight (clawsqlite build-interest-clusters) ---
# Fraction of tag embedding vs summary embedding when computing interest
# vectors inside clawsqlite. 0.75 means 75% tag, 25% summary.
CLAWSQLITE_INTEREST_TAG_WEIGHT=0.75

# --- Scoring parameters (clawfeedradar) ---
# Recency/popularity bias weights (light bias by default).
CLAWFEEDRADAR_W_RECENCY=0.05
CLAWFEEDRADAR_W_POPULARITY=0.05
# Recency half-life in days (e.g. 3 days).
CLAWFEEDRADAR_RECENCY_HALF_LIFE_DAYS=3

# S-shaped sigmoid steepness around 0.5 for interest_score.
# Larger K makes the curve steeper (more values pushed towards 0/1).
CLAWFEEDRADAR_INTEREST_SIGMOID_K=4.0

# Source-specific extra weights (used in compute_final_score).
CLAWFEEDRADAR_LAMBDA_HN=0.2
CLAWFEEDRADAR_LAMBDA_ARXIV=0.1

# Default maximum items per run when --max-items is omitted.
CLAWFEEDRADAR_MAX_ITEMS=12

# --- Tagging LLM ---
# Maximum number of tags per item (prompt hint only).
CLAWFEEDRADAR_LLM_TAG_MAX_PER_ITEM=12

# --- Small LLM for summaries / translation ---
# This model is used to generate preview summaries + bilingual body.
SMALL_LLM_BASE_URL=https://llm.example.com/v1
SMALL_LLM_MODEL=your-small-llm
SMALL_LLM_API_KEY=sk-your-small-llm-key

# Approximate context limits (token-based, converted to char budget internally).
# Humans think in tokens, the code multiplies by ~4 to get a coarse character budget.
CLAWFEEDRADAR_LLM_CONTEXT_TOKENS=8096

# Maximum characters per bilingual segment (one screen). Example: 2400 ≈ 600 Chinese characters.
CLAWFEEDRADAR_LLM_MAX_PARAGRAPH_CHARS=2400

# Translation / tagging call rate limiting.
# Calls are serialized; you can insert a sleep between calls (milliseconds)
# to avoid overloading a self-hosted small model.
CLAWFEEDRADAR_LLM_SLEEP_BETWEEN_MS=500

# Language preferences for LLM.
# SOURCE_LANG is usually "auto"; TARGET_LANG is your primary target language.
CLAWFEEDRADAR_LLM_SOURCE_LANG=auto
CLAWFEEDRADAR_LLM_TARGET_LANG=zh

# --- Optional: GitHub Pages publishing config ---
# If set, clawfeedradar can later be wired to sync generated XML to a
# GitHub Pages repo/branch/path. This is not implemented in v1 but the
# env names are reserved.
# CLAWFEEDRADAR_GITHUB_REPO=owner/repo
# CLAWFEEDRADAR_GITHUB_BRANCH=gh-pages
# CLAWFEEDRADAR_GITHUB_FEED_PATH=feeds/radar.xml
