# clawfeedradar ENV.example
# Copy this file to `.env` and replace placeholder values as needed.

# --- Embedding service (shared with clawsqlite) ---
EMBEDDING_BASE_URL=https://embed.example.com/v1
EMBEDDING_MODEL=your-embedding-model
EMBEDDING_API_KEY=sk-your-embedding-key

# Vector dimension for the embedding model (must match clawsqlite side)
CLAWSQLITE_VEC_DIM=1024

# --- Knowledge base location (clawsqlite) ---
# Root directory that contains knowledge.sqlite3 and articles/
CLAWSQLITE_ROOT=/home/node/.openclaw/workspace/knowledge_data
# Optional explicit DB path override
# CLAWSQLITE_DB=/home/node/.openclaw/workspace/knowledge_data/knowledge.sqlite3

# --- Output directory for feeds ---
# radar.xml and radar.json will be written here.
CLAWFEEDRADAR_OUTPUT_DIR=/home/node/.openclaw/workspace/clawfeedradar/feeds

# --- Small LLM for summaries / translation ---
# This model is used to turn fulltext into bilingual (EN/ZH) summaries.
SMALL_LLM_BASE_URL=https://llm.example.com/v1
SMALL_LLM_MODEL=your-small-llm
SMALL_LLM_API_KEY=sk-your-small-llm-key

# Approximate context limits (character-based, v0 implementation):
# Maximum number of input characters per LLM call. The implementation will
# chunk long articles so that each call uses at most this many characters
# for the source text, leaving enough room for the prompt and output.
CLAWFEEDRADAR_LLM_MAX_INPUT_CHARS=6000

# Expected maximum output characters per call (used only for planning;
# actual enforcement relies on the LLM provider).
CLAWFEEDRADAR_LLM_MAX_OUTPUT_CHARS=6000

# Translation call concurrency / rate limiting:
# v0: translation calls are strictly serialized (no parallel calls).
# You can optionally insert a sleep between calls (milliseconds) to avoid
# overloading a self-hosted small model.
CLAWFEEDRADAR_LLM_SLEEP_BETWEEN_MS=500

# Language preferences for translation:
# Comma-separated list of target languages. For the initial design we
# mainly care about bilingual EN/ZH output.
# Example: "en,zh" means keep English and generate Chinese; the renderer
# can decide how to layout the two.
CLAWFEEDRADAR_LLM_TARGET_LANGS=en,zh

# --- Interest mixing weight (clawsqlite build-interest-clusters) ---
# Fraction of tag embedding vs summary embedding when computing interest
# vectors inside clawsqlite. 0.75 means 75% tag, 25% summary.
CLAWSQLITE_INTEREST_TAG_WEIGHT=0.75

# --- Scoring & diversity controls (clawfeedradar) ---
# Main interest score weights
# CLAWFEEDRADAR_W_SIM_BEST=0.6
# CLAWFEEDRADAR_W_SIM_SECOND=0.2
# CLAWFEEDRADAR_W_RECENCY=0.1
# CLAWFEEDRADAR_W_POPULARITY=0.1
# Recency half-life in seconds (default: 3 days)
# CLAWFEEDRADAR_RECENCY_HALF_LIFE_SEC=259200
# Diversity: max items per interest cluster
# CLAWFEEDRADAR_PER_CLUSTER_CAP=3
# Exploration: number of "boundary" items to add
# CLAWFEEDRADAR_EXPLORE_COUNT=2
# Source-specific extra weights
# CLAWFEEDRADAR_LAMBDA_HN=0.2
# CLAWFEEDRADAR_LAMBDA_ARXIV=0.1

# --- Optional: GitHub Pages publishing config ---
# If set, clawfeedradar can (later) sync the generated radar.xml to this
# repo/branch/path so it is available via GitHub Pages.
# Repository in the form "owner/repo".
# CLAWFEEDRADAR_GITHUB_REPO=ernestyu/clawfeedradar-feed
# Branch used for pages (commonly gh-pages).
# CLAWFEEDRADAR_GITHUB_BRANCH=gh-pages
# Path on that branch where the feed XML should live.
# CLAWFEEDRADAR_GITHUB_FEED_PATH=feeds/radar.xml

# End of ENV.example

# --- Sources config for clawfeedradar schedule (JSON) ---
# Path to sources.json used by `clawfeedradar schedule`.
# CLAWFEEDRADAR_SOURCES_JSON=/home/node/.openclaw/workspace/clawfeedradar/clawfeedradar/sources.json
